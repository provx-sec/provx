# Provx environment - copy to `.env` and adjust. NEVER commit your real .env.
# The .env file is gitignored; only this example is tracked.

# ---- Postgres ----------------------------------------------------------------
POSTGRES_USER=provx
POSTGRES_PASSWORD=change-me-in-your-env
POSTGRES_DB=provx
# Consumed by the backend (host `db` is the compose service name):
DATABASE_URL=postgresql+asyncpg://provx:change-me-in-your-env@db:5432/provx

# ---- Redis (job queue for arq workers) ---------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- Backend -----------------------------------------------------------------
# Gates whether internal error detail is ever returned to a client. Anything other than
# local/development/testing/staging is treated as production and leaks nothing.
APP_ENV=production
BACKEND_PORT=8000
# Generate a strong random value in your real .env (e.g. `openssl rand -hex 32`):
SECRET_KEY=change-me-generate-a-random-secret

# ---- Frontend ----------------------------------------------------------------
FRONTEND_PORT=3000
# The UI fetches findings in a Server Component, so this URL is resolved from inside the
# frontend container - use the compose service name, not localhost. Deliberately not
# NEXT_PUBLIC_: the API address must never ship in the browser bundle.
# Running `next dev` on the host instead? Use http://localhost:8000.
PROVX_API_BASE_URL=http://backend:8000

# ---- AI (OFF by default - bring your own key when you enable it) --------------
# Provx works fully with zero AI. Leave disabled unless you opt in.
AI_ENABLED=false
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-5
# AI_API_KEY=

# ---- Safety ------------------------------------------------------------------
# Org-wide safe-mode lock. When true, forces safety regardless of engagement mode.
SAFE_MODE=true

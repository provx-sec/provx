{# SPDX-License-Identifier: Apache-2.0 #}
{# Client-ready engagement report. Autoescaping is on: every dynamic value originates in scan
   output and is untrusted (rule S-06). Evidence is shown only as its sealed reference - the
   SHA-256 and capture time - never the raw body (rules PX-SECRETS, PX-EVIDENCE). #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Provx report - {{ report.branding.client_name }}</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem auto; max-width: 60rem; color: #1a1a1a; line-height: 1.5; }
    h1 { margin-bottom: 0.25rem; }
    h2 { margin-top: 2.5rem; border-bottom: 2px solid #e5e5e5; padding-bottom: 0.3rem; }
    h3 { margin-top: 1.75rem; }
    .classification { border: 2px solid #7f1d1d; background: #fef2f2; color: #7f1d1d; font-weight: 700; letter-spacing: 0.08em; text-align: center; text-transform: uppercase; padding: 0.6rem; border-radius: 6px; margin-bottom: 1.5rem; }
    .banner { border: 2px solid #b45309; background: #fffbeb; padding: 1rem; border-radius: 6px; margin: 1rem 0; }
    .banner strong { color: #92400e; }
    table { border-collapse: collapse; width: 100%; font-size: 0.9rem; margin: 0.5rem 0; }
    th, td { border: 1px solid #d4d4d4; padding: 0.5rem 0.65rem; text-align: left; vertical-align: top; }
    th { background: #f5f5f5; }
    code { background: #f5f5f5; padding: 0.1rem 0.3rem; border-radius: 3px; word-break: break-all; }
    .meta { color: #525252; font-size: 0.85rem; }
    .empty { padding: 2rem; text-align: center; color: #525252; border: 1px dashed #d4d4d4; border-radius: 6px; }
    .finding { border: 1px solid #e5e5e5; border-radius: 6px; padding: 0.5rem 1rem 1rem; margin: 1rem 0; }
    .finding th { width: 12rem; white-space: nowrap; }
    .badge { display: inline-block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 0.1rem 0.5rem; border-radius: 999px; }
    .sev-critical { background: #7f1d1d; color: #fff; }
    .sev-high { background: #b91c1c; color: #fff; }
    .sev-medium { background: #b45309; color: #fff; }
    .sev-low { background: #ca8a04; color: #fff; }
    .sev-info { background: #475569; color: #fff; }
  </style>
</head>
<body>
{% macro sev_badge(severity) -%}
<span class="badge sev-{{ severity.value }}">{{ severity.value }}</span>
{%- endmacro %}

{% macro summary_table(rows) %}
<table>
  <thead>
    <tr><th>ID</th><th>Finding</th><th>Target</th><th>Severity</th><th>Status</th></tr>
  </thead>
  <tbody>
    {% for finding in rows %}
    <tr>
      <td><code>{{ finding.display_id }}</code></td>
      <td>{{ finding.title }}</td>
      <td>{{ finding.target }}</td>
      <td>{{ sev_badge(finding.severity) }}</td>
      <td>{{ finding.status.value }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endmacro %}

{% macro detail(finding) %}
<article class="finding">
  <h3><code>{{ finding.display_id }}</code> {{ finding.title }} {{ sev_badge(finding.severity) }}</h3>
  <table>
    <tr><th>Target</th><td>{{ finding.target }}{% if finding.location %} ({{ finding.location }}){% endif %}</td></tr>
    <tr><th>Severity</th><td>{{ finding.severity.value }}</td></tr>
    <tr><th>CVSS</th><td>{{ '%.1f' % finding.cvss if finding.cvss is not none else '-' }}</td></tr>
    <tr><th>Module</th><td>{{ finding.module.value }}</td></tr>
    <tr><th>MITRE ATT&amp;CK</th><td>{{ finding.attack_techniques | join(', ') or '-' }}</td></tr>
    <tr><th>Lifecycle state</th><td>{{ finding.status.value }} (confidence: {{ finding.confidence.value }})</td></tr>
    <tr><th>Description</th><td>{{ finding.description or finding.title }}</td></tr>
    <tr><th>Evidence reference</th><td>
      {%- if finding.evidence_sha256 -%}
      sha256 <code>{{ finding.evidence_sha256 }}</code>
      {%- if finding.captured_at %} &middot; captured {{ finding.captured_at.strftime('%Y-%m-%d %H:%M:%S %Z') }}{% endif -%}
      {%- else -%}-{%- endif -%}
    </td></tr>
    <tr><th>Remediation</th><td>{{ finding.remediation or '-' }}</td></tr>
  </table>
</article>
{% endmacro %}

  <div class="classification">{{ report.branding.classification or 'UNCLASSIFIED' }}</div>

  <h1>{{ report.branding.client_name }}</h1>
  <p class="meta">
    Security validation report &middot; mode {{ report.mode }} &middot;
    generated {{ report.generated_at.strftime('%Y-%m-%d %H:%M:%S %Z') }}<br>
    Prepared by {{ report.branding.tester_org or '-' }}
    {%- if report.branding.tester_name %} &middot; {{ report.branding.tester_name }}{% endif %}
    {%- if report.branding.tester_contact %} &middot; {{ report.branding.tester_contact }}{% endif %}
  </p>

  <h2>1. Executive summary</h2>
  <p>
    This assessment recorded <strong>{{ report.total }}</strong> in-report finding(s).
    Overall risk posture: <strong>{{ report.risk_posture }}</strong>.
  </p>
  <table>
    <thead><tr><th>Severity</th><th>Count</th></tr></thead>
    <tbody>
      {% for row in report.severity_counts %}
      <tr><td>{{ sev_badge(row.severity) }} {{ row.label }}</td><td>{{ row.count }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="meta">
    {{ report.validated_findings | length }} human-validated &middot;
    {{ report.machine_findings | length }} machine-found (unvalidated). Severity definitions:
    Critical/High findings warrant urgent action; Medium is a planned fix; Low/Info are
    hardening opportunities.
  </p>

  <h2>2. Scope &amp; rules of engagement</h2>
  <table>
    <tr><th>Client</th><td>{{ report.branding.client_name }}</td></tr>
    <tr><th>Testing mode</th><td>{{ report.mode }}</td></tr>
    <tr><th>In scope</th><td>{{ report.scope_allow | join(', ') or '-' }}</td></tr>
    <tr><th>Out of scope</th><td>{{ report.scope_deny | join(', ') or '-' }}</td></tr>
  </table>
  <p class="meta">
    Testing was constrained to the in-scope hosts above and enforced at the request boundary.
    Passive mode is read-only; intrusive checks run only under a recorded Active-mode
    authorization.
  </p>

  <h2>3. Methodology</h2>
  <p>
    Findings are produced by deterministic, industry-standard passive checks and mapped to
    the MITRE ATT&amp;CK framework. Each finding is de-duplicated, carries a severity and
    (where applicable) a CVSS score, and moves through a human validation lifecycle before it
    is treated as confirmed. No result depends on an AI model.
  </p>

  <h2>4. Findings summary</h2>
  {% if report.findings %}
  {{ summary_table(report.findings) }}
  {% else %}
  <p class="empty">No findings are currently in-report for this engagement.</p>
  {% endif %}

  <h2>5. Detailed findings</h2>

  <h3>Human-validated findings ({{ report.validated_findings | length }})</h3>
  <p class="meta">Confirmed by a reviewer. These are the findings that belong in the report.</p>
  {% if report.validated_findings %}
  {% for finding in report.validated_findings %}{{ detail(finding) }}{% endfor %}
  {% else %}
  <p class="empty">No findings have been human-validated yet.</p>
  {% endif %}

  {# PX-HUMAN: the machine proposes, a human confirms. Nothing in this section is confirmed. #}
  <div class="banner">
    <strong>Machine-found, unvalidated.</strong>
    Every finding in this section was produced automatically by a deterministic passive check
    and has <strong>not</strong> been confirmed by a human. Treat these as candidates for
    review, not as verified vulnerabilities. Findings must pass human validation before they
    belong in a client-facing report.
  </div>

  <h3>Machine-found, unvalidated ({{ report.machine_findings | length }})</h3>
  {% if report.machine_findings %}
  {% for finding in report.machine_findings %}{{ detail(finding) }}{% endfor %}
  {% else %}
  <p class="empty">No unvalidated findings are currently in-report.</p>
  {% endif %}

  <h2>6. MITRE ATT&amp;CK coverage</h2>
  {% if report.attack_coverage %}
  <table>
    <thead><tr><th>Tactic</th><th>Technique</th><th>ID</th><th>Findings</th></tr></thead>
    <tbody>
      {% for tactic in report.attack_coverage %}
      {% for technique in tactic.techniques %}
      <tr>
        {% if loop.first %}<td rowspan="{{ tactic.techniques | length }}">{{ tactic.tactic }}</td>{% endif %}
        <td>{{ technique.name }}</td>
        <td><code>{{ technique.technique }}</code></td>
        <td>{{ technique.count }}</td>
      </tr>
      {% endfor %}
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="empty">No ATT&amp;CK techniques are mapped for the in-report findings.</p>
  {% endif %}

  <h2>7. Remediation roadmap</h2>
  {% if report.remediation_roadmap %}
  {% for band in report.remediation_roadmap %}
  <h3>{{ sev_badge(band.severity) }} {{ band.label }} &mdash; {{ band.priority_window }}</h3>
  <table>
    <thead><tr><th>ID</th><th>Finding</th><th>Recommended action</th></tr></thead>
    <tbody>
      {% for finding in band.findings %}
      <tr>
        <td><code>{{ finding.display_id }}</code></td>
        <td>{{ finding.title }}</td>
        <td>{{ finding.remediation or '-' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endfor %}
  {% else %}
  <p class="empty">No remediation actions are required.</p>
  {% endif %}
</body>
</html>
